{
  "name": "cypressproject",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "cy:run:sauce": "cypress run --spec 'cypress/ui/sauce/sauce.cy.ts'",
    "test:unit": "cypress run --spec 'cypress/unit/**/*.cy.ts'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "depcruise": "depcruise --config .dependency-cruiser.cjs cypress/pages cypress/locators cypress/ui cypress/backend cypress/accessibility cypress/performance cypress/integration cypress/support cypress/utils"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^23.2.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.7",
    "@faker-js/faker": "^10.1.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "allure-cypress": "^3.4.2",
    "axe-core": "^4.11.4",
    "cypress": "^15.8.0",
    "cypress-axe": "^1.7.0",
    "cypress-image-diff-js": "^2.5.0",
    "dependency-cruiser": "^16.10.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "sqlite3": "^5.1.7",
    "typescript": "^5.9.3"
  }
}
