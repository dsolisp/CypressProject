# ═══════════════════════════════════════════════════════════════════════════════
# CypressProject .gitignore
# 7 Laws of QA Automation — Law 3: Repeatability (no local state committed)
# ADR-009: Auth state must never be committed
# ═══════════════════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build & Cache ─────────────────────────────────────────────────────────────
dist/
.cache/
.parcel-cache/

# ── Cypress test outputs ───────────────────────────────────────────────────────
cypress/screenshots/
cypress/videos/
cypress/downloads/

# ── Visual regression artifacts ────────────────────────────────────────────────
# Keep committed baselines, ignore generated actual/diff output
cypress-image-diff-screenshots/**
!cypress-image-diff-screenshots/baseline/**
cypress-image-diff-html-report/
cypress/snapshots/actual/
cypress/snapshots/diff/

# ── Allure reporting ──────────────────────────────────────────────────────────
allure-results/
allure-report/

# ── Auth state (ADR-009) ──────────────────────────────────────────────────────
.auth/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Database artifacts ────────────────────────────────────────────────────────
*.db
*.sqlite

# ── Legacy contract-testing outputs (Pact removed) ────────────────────────────
pacts/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# ── IDE files ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── Personal / non-project files ──────────────────────────────────────────────
english_exam_refresher.md
resume2_optimized.html
QUICKSTART.md
TUTORIAL_COMPLETE.md
